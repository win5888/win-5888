<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prediction Game</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans">

    <nav class="bg-blue-600 p-4 text-white flex justify-between">
        <h1 class="font-bold">PredictPro 4D</h1>
        <button onclick="toggleAdmin()" class="text-xs bg-blue-800 px-2 py-1 rounded">Admin Panel</button>
    </nav>

    <main id="user-section" class="p-4">
        <div class="bg-white p-6 rounded-xl shadow-md mb-6">
            <h2 class="text-xl font-bold mb-4">Submit Prediction</h2>
            <input id="user-number" type="number" placeholder="Enter 4 Digits (0000-9999)" 
                   class="w-full border p-3 rounded mb-4 text-lg tracking-widest">
            <button onclick="submitPrediction()" class="w-full bg-green-500 text-white font-bold py-3 rounded">Submit Entry</button>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-md">
            <h2 class="text-xl font-bold mb-4">Latest Results</h2>
            <div id="results-display" class="grid grid-cols-1 gap-2">
                <p class="text-gray-500 italic">Waiting for Admin to update today's results...</p>
            </div>
        </div>
    </main>

    <section id="admin-section" class="hidden p-4 bg-gray-200 min-h-screen">
        <h2 class="text-2xl font-bold mb-4">Admin Control</h2>
        <div class="bg-white p-6 rounded-xl shadow-md">
            <h3 class="font-bold mb-2">Input Winning Numbers</h3>
            <input id="win-magnum" type="text" placeholder="Magnum Result" class="w-full border p-2 mb-2">
            <input id="win-toto" type="text" placeholder="Toto Result" class="w-full border p-2 mb-2">
            <input id="win-damacai" type="text" placeholder="Da Ma Cai Result" class="w-full border p-2 mb-4">
            <button onclick="updateResults()" class="w-full bg-red-500 text-white font-bold py-3 rounded">Publish & Calculate Scores</button>
        </div>
    </section>

    <script>
        function toggleAdmin() {
            document.getElementById('user-section').classList.toggle('hidden');
            document.getElementById('admin-section').classList.toggle('hidden');
        }

        async function submitPrediction() {
            const num = document.getElementById('user-number').value;
            if(num.length !== 4) return alert("Please enter exactly 4 digits");
            
            // In a real app, this sends data to your server
            alert("Prediction " + num + " submitted for the next draw!");
        }
    </script>
</body>
</html>
